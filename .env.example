# =============================================================================
# Desoutter Assistant - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# Priority: Environment variables > .env file > config/ai_settings.py defaults
# =============================================================================

# =============================================================================
# MONGODB CONFIGURATION
# =============================================================================
# MongoDB stores users, feedback, learned mappings, and system metadata
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=desoutter
MONGO_URI=mongodb://mongodb:27017/

# Optional: MongoDB authentication (recommended for production)
# MONGO_USERNAME=admin
# MONGO_PASSWORD=your_secure_password

# =============================================================================
# QDRANT VECTOR DATABASE CONFIGURATION
# =============================================================================
# Qdrant stores 26,513 document embeddings for semantic search
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=desoutter_docs_v2

# Optional: Qdrant API key for cloud deployment
# QDRANT_API_KEY=your_api_key_here

# =============================================================================
# OLLAMA LLM CONFIGURATION
# =============================================================================
# Ollama provides local LLM inference with GPU acceleration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT=120
OLLAMA_MAX_TOKENS=512

# =============================================================================
# EMBEDDING MODEL CONFIGURATION
# =============================================================================
# Embeddings convert text to 384-dimensional vectors for semantic search
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cuda  # Use 'cpu' if no GPU available
EMBEDDING_DIMENSION=384
EMBEDDING_POOLING=mean
EMBEDDING_BATCH_SIZE=64

# =============================================================================
# RAG (RETRIEVAL AUGMENTED GENERATION) SETTINGS
# =============================================================================
# Core RAG parameters for document retrieval and response generation

# Number of documents to retrieve for context (increased for multi-step procedures)
RAG_TOP_K=7

# Minimum similarity score to consider a document relevant (0.0-1.0)
# Lower = more permissive, Higher = stricter matching
RAG_SIMILARITY_THRESHOLD=0.30

# Text chunking settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# =============================================================================
# HYBRID SEARCH CONFIGURATION
# =============================================================================
# Combines semantic (dense) and BM25 (sparse) retrieval for better coverage

# Enable hybrid search (true/false)
USE_HYBRID_SEARCH=true

# Weight for semantic search (0.0-1.0)
HYBRID_SEMANTIC_WEIGHT=0.6

# Weight for BM25 keyword search (0.0-1.0)
HYBRID_BM25_WEIGHT=0.4

# RRF (Reciprocal Rank Fusion) constant
HYBRID_RRF_K=60

# Query expansion with domain synonyms
ENABLE_QUERY_EXPANSION=true
MAX_QUERY_EXPANSIONS=3

# =============================================================================
# METADATA BOOSTING SETTINGS
# =============================================================================
# Boost certain document types for better relevance

ENABLE_METADATA_BOOST=true

# Boost factor for service bulletins (ESB/ESD documents)
SERVICE_BULLETIN_BOOST=4.0

# Boost factor for procedure sections
PROCEDURE_BOOST=1.3

# Boost factor for warning/caution sections
WARNING_BOOST=1.2

# Importance score multiplier
IMPORTANCE_BOOST_FACTOR=0.3

# =============================================================================
# CONTEXT GROUNDING CONFIGURATION
# =============================================================================
# Prevents hallucinations by refusing to answer when context is insufficient

ENABLE_CONTEXT_GROUNDING=true

# Overall sufficiency threshold (0.0-1.0)
# 0.3 = permissive, 0.5 = balanced, 0.7 = strict
CONTEXT_SUFFICIENCY_THRESHOLD=0.5

# Minimum similarity for top document to consider answering
MIN_SIMILARITY_FOR_ANSWER=0.35

# Minimum number of relevant documents for confident answer
MIN_DOCS_FOR_CONFIDENCE=2

# =============================================================================
# RESPONSE VALIDATION CONFIGURATION
# =============================================================================
# Post-processing validation to detect hallucinations and quality issues

ENABLE_RESPONSE_VALIDATION=true
FLAG_UNCERTAINTY_PHRASES=true
VERIFY_NUMERICAL_VALUES=true
MIN_RESPONSE_LENGTH=30
MAX_UNCERTAINTY_COUNT=2

# =============================================================================
# PERFORMANCE OPTIMIZATION
# =============================================================================
# Caching and optimization options

# Response caching (LRU + TTL)
USE_CACHE=true
CACHE_TTL=3600

# Feature flags for performance testing
ENABLE_DOMAIN_EMBEDDINGS=false
ENABLE_FAULT_FILTERING=false
ENABLE_ADAPTIVE_CHUNKING=false

# LLM generation timeout in seconds
LLM_TIMEOUT_SECONDS=10

# =============================================================================
# DEDUPLICATION CONFIGURATION
# =============================================================================
# Prevents duplicate content from bloating the vector database

ENABLE_DEDUPLICATION=true
LOG_DUPLICATE_RATIO=true

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================
# FastAPI web server settings

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false  # Set to 'true' for development

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT secret for token signing (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-secure-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS origins (comma-separated, use '*' for development only)
CORS_ORIGINS=*

# =============================================================================
# LANGUAGE SETTINGS
# =============================================================================
# Default response language: 'en' (English) or 'tr' (Turkish)
DEFAULT_LANGUAGE=en

# =============================================================================
# DOCUMENT PROCESSING SETTINGS
# =============================================================================
# PDF/DOCX/PPTX processing configuration

PDF_EXTRACT_IMAGES=false
PDF_EXTRACT_TABLES=true

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Control logging verbosity and output

LOG_LEVEL=INFO
LOG_FILE=data/logs/scraper.log
LOG_QUERIES=true
LOG_RESPONSES=true

# =============================================================================
# OPTIONAL: NVIDIA GPU CONFIGURATION
# =============================================================================
# Set if using NVIDIA GPU for acceleration
# NVIDIA_VISIBLE_DEVICES=all
# CUDA_VISIBLE_DEVICES=0

# =============================================================================
# OPTIONAL: DOMAIN EMBEDDINGS (Future Enhancement)
# =============================================================================
# Enable when fine-tuned domain-specific embeddings are available
# USE_DOMAIN_EMBEDDINGS=false
# DOMAIN_EMBEDDING_MODEL_PATH=/path/to/fine-tuned-model
# DOMAIN_EMBEDDING_TRAINING_ENABLED=false
